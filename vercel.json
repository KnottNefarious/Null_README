{
  "rewrites": [
    { "source": "/draw", "destination": "/draw.html" },
    { "source": "/", "destination": "/draw.html" }
  ],
  "headers": [
    {
      "source": "/api/canvas.svg",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ]
}
