# NULL CANVAS — Environment Variables
# Copy this file, rename to .env, and fill in your values.
# Then paste each value into Vercel's dashboard under Project → Settings → Environment Variables.
# NEVER commit .env to git. It is in .gitignore.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── GitHub OAuth App ──────────────────────────────────────────────────────────
# Found in: GitHub → Settings → Developer Settings → OAuth Apps → Your App
# Homepage URL: https://null-readme.vercel.app
# Callback URL: https://null-readme.vercel.app/api/auth/callback
GITHUB_CLIENT_ID=Ov23li...
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# ── JWT Secret ────────────────────────────────────────────────────────────────
# Generate a random 32+ character string. Example (run in terminal):
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_random_string_here_at_least_32_chars

# ── Your Repo Info ────────────────────────────────────────────────────────────
# Your GitHub username (owner of the Null_README repo)
REPO_OWNER=your_github_username
REPO_NAME=Null_README

# ── Your Vercel URL ───────────────────────────────────────────────────────────
# Your deployed Vercel project URL (no trailing slash)
SITE_URL=https://null-readme.vercel.app
